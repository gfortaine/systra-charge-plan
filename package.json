{
  "name": "myapp",
  "description": "Myapp frontend",
  "author": "Systra SDS",
  "license": "Proprietary",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "list": "node -e 'console.log(Object.keys(require(\"./package.json\").scripts).join(\"\\n\"))'",
    "clean": "rm -rf front/dist front/src/config.js front/src/translations.json",
    "pre": "yarn run gen-config; yarn run gen-scss; yarn run i18n-compile",
    "gen-config": "[ -e front/src/config.js ] || sed -E -e \"s|###MAPBOX_PUBLIC_KEY###|${MAPBOX_PUBLIC_KEY}|\" front/src/config.js.dist > front/src/config.js",
    "build": "yarn run pre && vite -c front/vite.config.js build",
    "start": "yarn run pre >/dev/null && vite -c front/vite.config.js",
    "preview": "vite -c front/vite.config.js preview",
    "lint": "ko=0; yarn run -s jslint || ko=1; yarn run -s csslint || ko=1; [ ! $ko -eq 1 ]",
    "jslint": "eslint .",
    "csslint": "stylelint 'front/src/**/*.{scss,css}'",
    "gen-scss": "node front/src/scss/sass-js-importer.js ./front/src/scss/sds-design-system/color-shades.js > ./front/src/scss/sds-design-system/color-shades.scss",
    "i18n-extract": "./front/.scripts/gettext-extract",
    "i18n-compile": "./front/.scripts/gettext-compile",
    "i18n-report": "./front/.scripts/gettext-report",
    "test": "sh -c 'if [ -n \"$QUICK\" ]; then vitest -c front/vite.config.js --run --no-coverage \"$@\"; else yarn run pre && vitest -c front/vite.config.js \"$@\"; fi' --",
    "test-report": "./front/.scripts/gen_report_html",
    "test-ui": "vitest -c front/vite.config.js --ui"
  },
  "@comment dependencies": {
    "react": "Component engine",
    "react-dom": "React for browser DOM",
    "react-hook-form": "React forms validation",
    "node-gettext/lioness": "Used by lioness for i18n, should be specified until lioness is patched #63",
    "@mui/material": "React component library that implements Google's Material Design",
    "@mui/icons-material": "Material UI Icons library",
    "@mui/styled-engine": "Material UI Styled engine",
    "@emotion/*": "Implementations for @mui/styled-engine",
    "@mui/x-*": "React component libraries",
    "mapbox-gl": "To draw maps and geographic features",
    "graphql": "JavaScript reference implementation for GraphQL",
    "graphql-request": "GraphQL client supporting Node and browsers",
    "@apollo/client": "To make http request",
    "apollo-upload-client": "To allow to upload binary files with Graphql",
    "rxjs": "Required only by apollo-upload-client",
    "moment": "Dates with timezone"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/styled-engine": "^7.3.9",
    "@mui/x-charts": "^8.27.0",
    "@mui/x-data-grid": "^8.27.3",
    "@mui/x-date-pickers": "^8.27.0",
    "apollo-upload-client": "^19.0.0",
    "graphql": "^16.11.0",
    "graphql-request": "^7.4.0",
    "mapbox-gl": "^3.18.1",
    "moment": "^2.30.1",
    "node-gettext": "^3.0.1",
    "react": "^19.2",
    "react-dom": "^19.2",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "rxjs": "^7.8.2"
  },
  "@comments devDependencies": {
    "vite": "Bundler and runner",
    "@vitejs/plugin-react": "React plugin for Vite",
    "vitest": "Jest-like test runner for Vite",
    "@vitest/coverage-istanbul": "Coverage, using istanbul, for vitest. In place of v8 that gives bad coverage result",
    "@vitest/ui": "Allow to drive vitest from the browser",
    "gettext-utils": "Allow to extract and compile po files to json",
    "jsdom": "Vitest environment with many browser features implemented",
    "djvite": "Integration with Django",
    "eslint": "Javascript linter, import @eslint/js is better???",
    "eslint-config-standard": "Basic standard eslint config",
    "eslint-plugin-import": "Import rules for eslint",
    "eslint-plugin-n": "Node rules for eslint",
    "eslint-plugin-promise": "Promise rules for eslint",
    "eslint-plugin-react": "React support for eslint",
    "eslint-plugin-react-hooks": "Linter plugin to check hooks dependencies",
    "eslint-plugin-react-refresh": "Validate that components can safely be updated with Fast Refresh",
    "@stylistic/eslint-plugin": "Plugin that contains recommended rules because they have been deprecated in ESLint",
    "rollup-plugin-react-scoped-css": "Scoped CSS with React",
    "sass": "CSS templating",
    "stylelint": "CSS linter",
    "stylelint-config-standard-scss": "Sass linter rules",
    "xunit-viewer": "Html report from xunit report"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.1.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "djvite": "^1.4.3",
    "eslint": "^9",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.21.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gettext-utils": "^2.2.1",
    "glob": "^13.0.6",
    "jsdom": "^28.1.0",
    "rollup-plugin-react-scoped-css": "^1.2.1",
    "sass": "^1.86.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^7.1.4",
    "vitest": "^4.0.18",
    "xunit-viewer": "^10.6.1"
  },
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "immutable": "^5.1.5",
    "minimatch": "^10.2.3",
    "rollup": "^4.59.0"
  },
  "engines": {
    "node": ">= 22.0.0"
  }
}
